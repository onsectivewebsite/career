<header class="bg-white border-b border-slate-200 sticky top-0 z-40">
  <div class="container-xl flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3">
      <img src="/static/img/logo.png" alt="Onsective" class="h-8 w-auto">
      <span class="hidden sm:inline text-sm text-slate-500">Careers</span>
    </a>
    <nav class="flex items-center gap-6 text-sm font-medium text-slate-700">
      <a class="hover:text-brand-500" href="/careers">Jobs</a>
      <a class="hover:text-brand-500" href="/leadership">Leadership</a>
      <a class="hover:text-brand-500" href="/life">Life at Onsective</a>
      <a class="hover:text-brand-500" href="/contact">Contact</a>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'admin' || currentUser.role === 'hr') { %>
          <a class="hover:text-brand-500" href="/admin">Admin</a>
        <% } else if (currentUser.role === 'employee') { %>
          <a class="hover:text-brand-500" href="/employee">Employee</a>
        <% } else { %>
          <a class="hover:text-brand-500" href="/candidate">My applications</a>
        <% } %>
        <form action="/logout" method="post" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="text-slate-500 hover:text-rose-600">Sign out</button>
        </form>
        <span class="hidden md:inline text-xs text-slate-500">· <%= currentUser.name %></span>
      <% } else { %>
        <a class="btn-ghost !py-2 !px-3 text-sm" href="/login">Sign in</a>
      <% } %>
    </nav>
  </div>
</header>
<% if (flash) { %>
  <div class="container-xl mt-4">
    <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-rose-50 text-rose-800 border border-rose-200' : flash.type === 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-blue-50 text-blue-800 border border-blue-200' %>">
      <%= flash.message %>
    </div>
  </div>
<% } %>
