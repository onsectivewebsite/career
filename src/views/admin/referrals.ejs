<%- include('../partials/head', { title: title }) %>
<%- include('../partials/nav') %>

<section class="container-xl py-10">
  <div class="flex flex-col md:flex-row gap-8">
    <%- include('../partials/admin-sidebar') %>
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-ink-900 mb-6">Referrals</h1>

      <% if (refs.length === 0) { %>
        <div class="card p-10 text-center text-slate-500">No referrals yet.</div>
      <% } else { %>
        <div class="card overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-left text-slate-500 text-xs uppercase">
              <tr>
                <th class="px-5 py-3">Referrer</th>
                <th class="px-5 py-3">Candidate</th>
                <th class="px-5 py-3">Role</th>
                <th class="px-5 py-3">When</th>
                <th class="px-5 py-3">Status</th>
              </tr>
            </thead>
            <tbody>
              <% refs.forEach(r => { %>
                <tr class="border-t border-slate-200">
                  <td class="px-5 py-3"><%= r.employee_name %><div class="text-xs text-slate-500"><%= r.employee_email %></div></td>
                  <td class="px-5 py-3"><%= r.candidate_name %><div class="text-xs text-slate-500"><%= r.candidate_email %></div></td>
                  <td class="px-5 py-3"><%= r.job_title %></td>
                  <td class="px-5 py-3 text-slate-600"><%= formatDate(r.created_at) %></td>
                  <td class="px-5 py-3"><span class="badge <%= statusBadge(r.status) %>"><%= r.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
