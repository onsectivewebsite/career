<%- include('../partials/head', { title: title }) %>
<%- include('../partials/nav') %>

<section class="bg-white border-b border-slate-200">
  <div class="container-xl py-12">
    <a href="/careers" class="text-sm text-brand-500 font-medium hover:underline">← All roles</a>
    <div class="text-xs uppercase tracking-wider text-brand-500 font-semibold mt-4"><%= job.department %></div>
    <h1 class="text-3xl md:text-4xl font-bold text-ink-900 mt-2"><%= job.title %></h1>
    <div class="mt-3 flex flex-wrap gap-2 text-sm">
      <span class="badge bg-slate-100 text-slate-700"><%= job.location %></span>
      <span class="badge bg-slate-100 text-slate-700"><%= job.employment_type %></span>
      <span class="badge bg-slate-100 text-slate-700"><%= job.experience_level %></span>
      <% if (job.salary_range) { %><span class="badge bg-emerald-100 text-emerald-700"><%= job.salary_range %></span><% } %>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/careers/<%= job.id %>/apply" class="btn-primary">Apply now</a>
      <% if (currentUser && currentUser.role === 'employee') { %>
        <a href="/employee/refer/<%= job.id %>" class="btn-ghost">Refer someone</a>
      <% } %>
    </div>
  </div>
</section>

<section class="container-xl py-12 grid md:grid-cols-3 gap-10">
  <div class="md:col-span-2 space-y-10">
    <div>
      <h2 class="text-xl font-semibold text-ink-900 mb-3">About the role</h2>
      <div class="prose-plain"><%= job.description %></div>
    </div>
    <div>
      <h2 class="text-xl font-semibold text-ink-900 mb-3">What we're looking for</h2>
      <div class="prose-plain"><%= job.requirements %></div>
    </div>
    <% if (job.benefits) { %>
      <div>
        <h2 class="text-xl font-semibold text-ink-900 mb-3">What we offer</h2>
        <div class="prose-plain"><%= job.benefits %></div>
      </div>
    <% } %>
  </div>
  <aside class="space-y-4">
    <div class="card p-6">
      <div class="text-sm font-semibold text-ink-900 mb-3">At a glance</div>
      <dl class="text-sm space-y-3">
        <div><dt class="text-slate-500">Department</dt><dd><%= job.department %></dd></div>
        <div><dt class="text-slate-500">Location</dt><dd><%= job.location %></dd></div>
        <div><dt class="text-slate-500">Type</dt><dd><%= job.employment_type %></dd></div>
        <div><dt class="text-slate-500">Experience</dt><dd><%= job.experience_level %></dd></div>
        <% if (job.referral_bonus) { %>
          <div><dt class="text-slate-500">Referral bonus</dt><dd class="font-semibold text-emerald-700"><%= job.referral_bonus %></dd></div>
        <% } %>
      </dl>
      <a href="/careers/<%= job.id %>/apply" class="btn-primary w-full justify-center mt-6">Apply</a>
    </div>
    <div class="card p-6 bg-slate-50 border-dashed">
      <div class="text-sm font-semibold text-ink-900 mb-2">Know someone great?</div>
      <p class="text-sm text-slate-600 mb-4">Onsective employees can refer a friend for this role and earn a bonus when they're hired.</p>
      <a href="/employee" class="btn-ghost w-full justify-center">Employee referral</a>
    </div>
  </aside>
</section>

<%- include('../partials/footer') %>
