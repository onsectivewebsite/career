<%- include('../partials/head', { title: title }) %>
<%- include('../partials/nav') %>

<section class="bg-white border-b border-slate-200">
  <div class="container-xl py-14">
    <h1 class="text-3xl md:text-4xl font-bold text-ink-900">Open roles at Onsective</h1>
    <p class="text-slate-600 mt-2">Search and filter to find your fit.</p>
    <form method="get" class="mt-8 grid md:grid-cols-4 gap-3">
      <input name="q" value="<%= filters.q || '' %>" placeholder="Search title, skills, keywords" class="input md:col-span-2">
      <select name="department" class="input">
        <option value="">All departments</option>
        <% departments.forEach(d => { %>
          <option value="<%= d %>" <%= filters.department === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
      </select>
      <select name="type" class="input">
        <option value="">All types</option>
        <% types.forEach(t => { %>
          <option value="<%= t %>" <%= filters.type === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <input name="location" value="<%= filters.location || '' %>" placeholder="Location" class="input md:col-span-2">
      <button class="btn-primary md:col-span-2 justify-center">Search</button>
    </form>
  </div>
</section>

<section class="container-xl py-12">
  <div class="text-sm text-slate-500 mb-4"><%= jobs.length %> role<%= jobs.length === 1 ? '' : 's' %> found</div>
  <% if (jobs.length === 0) { %>
    <div class="card p-10 text-center text-slate-500">No roles match your filters. Try broadening them.</div>
  <% } else { %>
    <div class="space-y-3">
      <% jobs.forEach(job => { %>
        <a href="/careers/<%= job.id %>" class="card p-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4 hover:shadow-md transition">
          <div>
            <div class="text-xs uppercase tracking-wider text-brand-500 font-semibold mb-1"><%= job.department %></div>
            <div class="text-lg font-semibold text-ink-900"><%= job.title %></div>
            <div class="text-sm text-slate-500 mt-1"><%= job.summary %></div>
          </div>
          <div class="flex flex-wrap gap-2 text-xs">
            <span class="badge bg-slate-100 text-slate-700"><%= job.location %></span>
            <span class="badge bg-slate-100 text-slate-700"><%= job.employment_type %></span>
            <span class="badge bg-slate-100 text-slate-700"><%= job.experience_level %></span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
