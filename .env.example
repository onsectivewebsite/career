# Onsective Careers — copy this file to .env and fill in real values.
# Never commit the real .env. Rotate any secret that ends up in chat or email.

NODE_ENV=development
PORT=3100
APP_URL=http://localhost:3100
SESSION_SECRET=replace-with-a-long-random-string

# First-boot admin (created by seed; change password immediately after login)
ADMIN_EMAIL=admin@onsective.com
ADMIN_PASSWORD=replace-me
ADMIN_NAME=Site Administrator

# SMTP (Hostinger) — outgoing mail
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true

# System mailer (automated notifications)
MAIL_FROM_NAME=Onsective Careers
MAIL_FROM_ADDRESS=donotreply@onsective.com
MAIL_FROM_PASSWORD=replace-me

# Reply-to / careers mailbox
MAIL_CAREERS_ADDRESS=career@onsective.com
MAIL_CAREERS_PASSWORD=replace-me

# General info mailbox
MAIL_INFO_ADDRESS=info@onsective.com
MAIL_INFO_PASSWORD=replace-me

# IMAP / POP (reserved for future inbox-sync features)
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
POP_HOST=pop.hostinger.com
POP_PORT=995
